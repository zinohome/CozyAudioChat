# 复制为 .env 后按需修改：cp .env.example .env

# 镜像仓库与标签
HARBOR_REGISTRY=harbor.naivehero.top:8443/video
IMAGE_TAG=latest

# 前端对外端口（宿主机 -> 容器 80）
CLIENT_PORT=8080

# 推理服务
# 单卡共享填 0；双卡部署 TTS 用第二张卡填 1（并在 compose 放开 device_ids）
TTS_GPU=0
# 模型下载源：modelscope（国内推荐）| huggingface
DOWNLOAD_SOURCE=modelscope
S2S_MODEL_NAME=Fun-Audio-Chat-8B
